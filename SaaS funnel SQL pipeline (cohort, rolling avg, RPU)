### Query 7: Drop-off Analysis View
*/

CREATE OR REPLACE VIEW workspace.default.vw_dropoff AS
WITH stages AS (
    SELECT 'Initiated' AS stage, COUNT(*) AS cnt 
    FROM workspace.default.orders_clean
    UNION ALL
    SELECT 'Workflow', SUM(entered_workflow) 
    FROM workspace.default.orders_clean
    UNION ALL
    SELECT 'Login Attempt', SUM(attempted_login) 
    FROM workspace.default.orders_clean
    UNION ALL
    SELECT 'Login Success', SUM(login_success) 
    FROM workspace.default.orders_clean
    UNION ALL
    SELECT 'Completed', SUM(order_complete) 
    FROM workspace.default.orders_clean
)
SELECT 
    stage,
    cnt AS count,
    LAG(cnt) OVER (ORDER BY stage) AS previous_stage_count,
    ROUND((LAG(cnt) OVER (ORDER BY stage) - cnt) * 100.0 / 
          LAG(cnt) OVER (ORDER BY stage), 2) AS drop_off_rate_pct
FROM stages;

/*
**Result:** View created - Query the view:
*/

SELECT * FROM workspace.default.vw_dropoff
ORDER BY 
    CASE stage
        WHEN 'Initiated' THEN 1
        WHEN 'Workflow' THEN 2
        WHEN 'Login Attempt' THEN 3
        WHEN 'Login Success' THEN 4
        WHEN 'Completed' THEN 5
    END;

/*
**Output:**

| stage | count | previous_stage_count | drop_off_rate_pct |
|-------|-------|---------------------|-------------------|
| Initiated | 10,000 | - | - |
| Workflow | 5,112 | 10,000 | 48.88% |
| Login Attempt | 3,197 | 5,112 | 37.47% |
| Login Success | 745 | 3,197 | 76.70% 🔴 |
| Completed | 553 | 745 | 25.77% |

**Critical Findings:**
- 🔴 **76.70% drop-off at Login Success** - BIGGEST BOTTLENECK
- 48.88% abandon at workflow entry
- 37.47% drop at login attempt
- 25.77% abandon after successful login

**Recommendation:** Fix authentication flow immediately - this is losing 76% of engaged users!

