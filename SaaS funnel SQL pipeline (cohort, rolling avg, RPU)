### Query 9: A/B Test Results View
*/

CREATE OR REPLACE VIEW workspace.default.vw_ab_test AS
WITH base AS (
    SELECT
        a.variant,
        COUNT(*) AS users,
        ROUND(AVG(o.login_success) * 100, 2) AS conversion_rate
    FROM workspace.default.orders_clean o
    JOIN workspace.default.ab_assignments a ON o.order_id = a.order_id
    GROUP BY a.variant
)
SELECT 
    variant,
    users,
    conversion_rate,
    ROUND(conversion_rate - FIRST_VALUE(conversion_rate) OVER (ORDER BY variant), 2) AS lift_pct
FROM base
ORDER BY variant;

/*
**Result:** View created - Query the view:
*/

SELECT * FROM workspace.default.vw_ab_test;

/*
**Output:**

| variant | users | conversion_rate | lift_pct |
|---------|-------|-----------------|----------|
| control | 2,448 | 15.16% | 0.00% |
| variant_b | 2,449 | 15.27% | +0.11% |

**Test Results:**
- ✅ Variant B shows positive lift (+0.11%)
- ⚠️ Lift is marginal - test a more aggressive variant
- Sample size: ~2,450 users per variant (good statistical power)

